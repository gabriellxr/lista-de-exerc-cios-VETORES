#include <stdio.h>
#include <stdlib.h>

int main() {

    float numeros[10];
    float total = 0.0;
    float media = 0.0;

    for (int i = 0; i < 10; i++) {
        printf("Digite o %d numero: ", i + 1);
        scanf("%f", &numeros[i]);
    }

    for (int i = 0; i < 10; i++) {
        total = total + numeros[i];
    }

    media = total / 10.0;

    printf("\n resultado da media final e: %.2f\n\n", media);

    system("pause");
    return 0;
}
